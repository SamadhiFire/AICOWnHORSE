page{font-family:-apple-system,SF Pro Text,PingFang SC,MiSans,sans-serif;background-color:#f8f8f8;--oa-card-bg: #FFFFFF;--oa-card-border-color: #E8EAED;--oa-card-radius: 16rpx;--oa-modal-duration: .22s;--oa-fast-transition-duration: .2s}page,view,scroll-view,text,button,input,textarea,image,picker,open-data{font-family:inherit}scroll-view::-webkit-scrollbar{width:0;height:0;color:transparent;background:transparent;display:none}.oa-card-surface{border:1rpx solid var(--oa-card-border-color);border-radius:var(--oa-card-radius);background:var(--oa-card-bg)}button,input,textarea{transition:all var(--oa-fast-transition-duration) ease}.oa-modal-mask{animation:oa-modal-mask-fade-in var(--oa-modal-duration) ease both}.oa-modal-panel{animation:oa-modal-enter var(--oa-modal-duration) ease both}@keyframes oa-modal-mask-fade-in{0%{opacity:0}to{opacity:1}}@keyframes oa-modal-enter{0%{opacity:0;transform:scale(.9)}to{opacity:1;transform:scale(1)}}page{--oa-title: #1A1A1A;--oa-text: #3C4043;--oa-sub: #70757A;--oa-border-color: #E8EAED;--oa-radius: 8rpx;--oa-card: #ffffff;--oa-card-strong: #ffffff;--oa-accent: #07C160;--oa-accent-2: #07C160;--oa-accent-3: #07C160;--oa-danger: #cf5656;background:#f8f8f8;color:var(--oa-text);font-family:-apple-system,SF Pro Text,PingFang SC,MiSans,sans-serif}page,view,scroll-view,text,button,input,textarea,image,picker,open-data{box-sizing:border-box}view,text,button,input,textarea,scroll-view,picker{font-family:inherit;color:inherit}button{letter-spacing:2rpx}button:after{border:0}.oa-page{min-height:100vh}.oa-scroll{position:relative;min-height:100vh;padding:0 40rpx calc(env(safe-area-inset-bottom) + 220rpx)}.oa-bg,.oa-halo{display:none}.oa-halo-a,.oa-halo-b,.oa-halo-c{background:transparent}.oa-header{position:relative;z-index:1;padding-top:calc(constant(safe-area-inset-top) + 26rpx);padding-top:calc(env(safe-area-inset-top) + 26rpx);padding-bottom:22rpx}.oa-kicker{display:inline-flex;align-items:center;padding:0;border-radius:var(--oa-radius);font-size:22rpx;color:var(--oa-sub);letter-spacing:0;text-transform:none;background:transparent}.oa-dot{display:none}.oa-title{margin-top:12rpx;font-size:44rpx;line-height:1.12;font-weight:600;letter-spacing:1rpx;color:var(--oa-title)}.oa-subtitle{margin-top:10rpx;font-size:24rpx;line-height:1.5;color:var(--oa-sub)}.oa-stack{position:relative;z-index:1;display:flex;flex-direction:column;gap:20rpx}.oa-card{position:relative;overflow:hidden;border:1rpx solid var(--oa-border-color);border-radius:var(--oa-radius);padding:22rpx;background:var(--oa-card)}.oa-card-strong{background:var(--oa-card-strong)}.oa-card-gradient{background:#fff}.oa-shape{display:none}.oa-shape-a,.oa-shape-b{background:transparent}.oa-card-head{display:flex;align-items:flex-start;justify-content:space-between;gap:14rpx;margin-bottom:14rpx}.oa-card-title{font-size:30rpx;line-height:1.3;font-weight:600;color:var(--oa-title)}.oa-note{font-size:22rpx;line-height:1.45;color:var(--oa-sub);text-align:right}.oa-field{border:1rpx solid var(--oa-border-color);border-radius:var(--oa-radius);padding:14rpx 16rpx;background:#fff}.oa-input,.oa-textarea,.oa-picker-label{width:100%;border:0;outline:none;background:transparent;color:var(--oa-text);font-size:27rpx;line-height:1.55}.oa-input{min-height:66rpx}.oa-textarea{min-height:230rpx}.oa-picker-label{min-height:66rpx;display:flex;align-items:center}.oa-row{display:flex;flex-wrap:wrap;gap:10rpx}.oa-chip{padding:11rpx 16rpx;border:1rpx solid var(--oa-border-color);border-radius:var(--oa-radius);font-size:23rpx;line-height:1.25;color:var(--oa-text);background:#fff}.oa-chip-active{border:1rpx solid var(--oa-accent);color:var(--oa-text);background:#fff}.oa-btn{width:100%;min-height:86rpx;border:1rpx solid var(--oa-accent);border-radius:var(--oa-radius);font-size:28rpx;font-weight:600;color:#fff;letter-spacing:2rpx;background:var(--oa-accent)}.oa-btn-alt,.oa-btn-soft{background:#fff;color:var(--oa-text);border-color:var(--oa-border-color)}.oa-btn-hover{opacity:.9;transform:scale(.992)}.oa-btn-small{width:auto;min-height:62rpx;padding:0 16rpx;font-size:23rpx}.oa-btn[disabled]{opacity:.5}.oa-meta-row{display:flex;flex-wrap:wrap;gap:8rpx;margin-top:8rpx}.oa-meta{padding:4rpx 10rpx;border:1rpx solid var(--oa-border-color);border-radius:var(--oa-radius);font-size:20rpx;color:var(--oa-sub);background:#fff}.oa-meta-hot{color:var(--oa-text);background:#fff;border:1rpx solid var(--oa-accent)}.oa-item{margin-top:12rpx;border:1rpx solid var(--oa-border-color);border-radius:var(--oa-radius);padding:18rpx;background:#fff}.oa-item-title{font-size:28rpx;line-height:1.5;font-weight:600}.oa-item-text{margin-top:8rpx;font-size:24rpx;line-height:1.62;color:var(--oa-text)}.oa-action-row{display:flex;flex-wrap:wrap;gap:8rpx;margin-top:12rpx}.oa-empty{padding:24rpx 10rpx 12rpx;color:var(--oa-sub);font-size:24rpx;line-height:1.7}.oa-error{margin-top:12rpx;max-width:100%;border:1rpx solid var(--oa-border-color);padding:12rpx 14rpx;border-radius:var(--oa-radius);background:#fff;color:#d93025;font-size:23rpx;line-height:1.52;word-break:break-all;overflow-wrap:anywhere;white-space:normal}.oa-break{word-break:break-all;overflow-wrap:anywhere}.oa-gap-10{margin-top:10rpx}.oa-gap-14{margin-top:14rpx}.oa-gap-16{margin-top:16rpx}.oa-mask{position:fixed;top:0;right:0;bottom:0;left:0;z-index:110;background:rgba(15,23,42,.22);display:flex;align-items:flex-end;justify-content:center;padding:0 40rpx calc(env(safe-area-inset-bottom) + 130rpx)}.oa-modal{width:100%;max-height:78vh;overflow-y:auto;border:1rpx solid var(--oa-border-color);border-radius:var(--oa-radius);padding:20rpx;background:#fff}.oa-modal-title{font-size:30rpx;font-weight:600}.oa-bottom-space{height:calc(env(safe-area-inset-bottom) + 20rpx)}.oa-scrollbar-stealth{width:calc(100% + 24rpx);margin-right:-24rpx;padding-right:24rpx}
